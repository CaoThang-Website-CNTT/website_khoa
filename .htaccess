RewriteEngine On
RewriteBase /website_khoa/

# Bỏ qua các request tài nguyên tĩnh trong thư mục public / assets / storage / api / 
RewriteCond %{REQUEST_URI} !^/(public|assets|storage|api)(/|$) [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

RewriteRule ^(.*)$ index.php [QSA,L]